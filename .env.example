# -----------------------------------------------------------------------------
# ANTHEM - Environment Configuration Template
# -----------------------------------------------------------------------------
# Instructions: Copy this file to '.env' and fill in your actual private keys.
# Do NOT commit your actual '.env' file containing active keys to Github!

# Server Configuration
NODE_ENV=development
PORT=3000

# Google Gemini API (Used for the intelligent AI Stylist & personal curated chat)
GEMINI_API_KEY=your_gemini_api_key_here

# Third-party styling or LLM proxies (Optional)
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
